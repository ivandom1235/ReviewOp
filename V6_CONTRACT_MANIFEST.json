{
  "version": "6.0.0",
  "runtime_contracts": {
    "dataset_builder": {
      "primary_artifacts": [
        "dataset_builder/output/benchmark/ambiguity_grounded/train.jsonl",
        "dataset_builder/output/benchmark/ambiguity_grounded/val.jsonl",
        "dataset_builder/output/benchmark/ambiguity_grounded/test.jsonl",
        "dataset_builder/output/benchmark/ambiguity_grounded/metadata.json"
      ],
      "required_fields": [
        "instance_id",
        "review_text",
        "domain",
        "gold_interpretations",
        "abstain_acceptable",
        "novel_acceptable",
        "ambiguity_score",
        "split_protocol"
      ]
    },
    "protonet": {
      "input_type": "benchmark",
      "required_output_fields": [
        "decision",
        "accepted_predictions",
        "novel_candidates",
        "abstain",
        "ambiguity_score",
        "novelty_score"
      ]
    },
    "backend_infer": {
      "required_response_fields": [
        "accepted_predictions",
        "abstained_predictions",
        "novel_candidates"
      ]
    }
  },
  "deprecated_signals": {
      "blocked_tokens": [
        "5.5-production",
        "reviewlevel",
        "episodic",
        "compat/protonet"
      ]
    }
}

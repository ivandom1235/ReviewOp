MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_local_password_here
MYSQL_DB=protodb

# Model Configuration (Local/HuggingFace)
SEQ2SEQ_MODEL_NAME=google/flan-t5-small
SEQ2SEQ_MAX_NEW_TOKENS=192
SEQ2SEQ_TEMPERATURE=0.0
HF_TOKEN=your_huggingface_token_here

# App & Feature Control
APP_ENV=dev
ENABLE_IMPLICIT=true
ENABLE_LLM_VERIFIER=true
IMPLICIT_MIN_CONFIDENCE=0.08

# LLM Selection (Rules-Only vs LLM-Integrated)
# Use 'groq' for Llama3 (highly recommended for speed/cost) or 'openai'
DEFAULT_LLM_PROVIDER=groq
LLM_TIMEOUT_SECONDS=60

# Groq Configuration (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI Configuration (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Prototypical Network Integration
PROTONET_MODE=import
PROTONET_URL=http://127.0.0.1:8011
## Global environment template
# Copy this file to `.env` and fill in your values.

# User identification
USER_NAME=Your Name
USER_EMAIL=you@example.com

# OpenAI / Groq credentials
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

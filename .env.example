MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_local_password_here
MYSQL_DB=protodb

# Model Configuration (Local/HuggingFace)
SEQ2SEQ_MODEL_NAME=google/flan-t5-small
SEQ2SEQ_MAX_NEW_TOKENS=192
SEQ2SEQ_TEMPERATURE=0.0
HF_TOKEN=your_huggingface_token_here

# App & Feature Control
APP_ENV=dev
ENABLE_IMPLICIT=true
ENABLE_LLM_VERIFIER=true
IMPLICIT_MIN_CONFIDENCE=0.08

# LLM Selection (Rules-Only vs LLM-Integrated)
# Use 'runpod', 'openai', 'anthropic', or 'ollama'
DEFAULT_LLM_PROVIDER=runpod
LLM_TIMEOUT_SECONDS=60

# RunPod Serverless Configuration (Highly recommended for V5)
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/your_endpoint_id/runsync

# OpenAI Configuration (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama Configuration (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Prototypical Network Integration
PROTONET_MODE=import
PROTONET_URL=http://127.0.0.1:8011

# Global environment template
# Copy this file to `.env` and fill in your values.

# User identification
USER_NAME=Your Name
USER_EMAIL=you@example.com

# App environment. Use `dev` for local work.
REVIEWOP_ENV=dev

# ------------------------------------------------------------------------------
# Backend Database
# ------------------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DB=protodb

# ------------------------------------------------------------------------------
# Explicit + Implicit Pipeline
# ------------------------------------------------------------------------------
SEQ2SEQ_MODEL_NAME=google/flan-t5-small
SEQ2SEQ_MAX_NEW_TOKENS=192
SEQ2SEQ_TEMPERATURE=0.0
ENABLE_IMPLICIT=true
ENABLE_LLM_VERIFIER=false

PROTONET_MODE=import
PROTONET_URL=http://127.0.0.1:8011
PROTONET_REQUEST_TIMEOUT_SECONDS=30
PROTONET_BUNDLE_PATH=protonet/metadata/model_bundle.pt
PROTONET_ENCODER_MODEL=sentence-transformers/all-MiniLM-L6-v2
IMPLICIT_MIN_CONFIDENCE=0.08
MAX_IMPLICIT_CANDIDATES=3
MAX_VERIFIED_PREDICTIONS=8

KG_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
OPEN_ASPECT_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ------------------------------------------------------------------------------
# LLM Provider Defaults
# ------------------------------------------------------------------------------
# Pick the default provider used by backend verifier and dataset_builder.
REVIEWOP_DEFAULT_LLM_PROVIDER=groq
# HTTP timeout for provider calls when no provider-specific timeout is set.
REVIEWOP_LLM_TIMEOUT_SECONDS=60

# Groq
# dataset_builder uses GROQ_MODEL when Groq is the active provider.
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Claude
# dataset_builder uses CLAUDE_MODEL when Claude is the active provider.
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_BASE_URL=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# OpenAI
# dataset_builder uses OPENAI_MODEL when OpenAI is the active provider.
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama
# dataset_builder uses OLLAMA_MODEL when Ollama is the active provider.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# ------------------------------------------------------------------------------
# Dataset Builder / External Endpoints
# ------------------------------------------------------------------------------
# Controls whether dataset_builder runs locally or via RunPod.
DATASET_BUILDER_PROCESSOR=local
# RunPod credentials for dataset_builder only.
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/your_llm_endpoint_id/runsync

# ------------------------------------------------------------------------------
# Frontend Vite (optional)
# ------------------------------------------------------------------------------
VITE_PROXY_TARGET=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:5173

# Optional model provider token (used by transformers/huggingface tooling)
HF_TOKEN=your_huggingface_token

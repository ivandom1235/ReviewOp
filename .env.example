MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_local_password_here
MYSQL_DB=protodb

SEQ2SEQ_MODEL_NAME=google/flan-t5-small
SEQ2SEQ_MAX_NEW_TOKENS=192
SEQ2SEQ_TEMPERATURE=0.0

APP_ENV=dev
ENABLE_IMPLICIT=true
ENABLE_LLM_VERIFIER=true

PROTONET_MODE=import
PROTONET_URL=http://127.0.0.1:8011
IMPLICIT_MIN_CONFIDENCE=0.08

LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL_NAME=llama3.1:8b
LLM_TIMEOUT_SECONDS=60

DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

HF_TOKEN=

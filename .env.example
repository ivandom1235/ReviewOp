# ==============================================================================
# ReviewOp Environment Configuration (V5.5 Research-Grade)
# ==============================================================================
# Instructions:
# 1. Copy this file to `.env` in the repository root.
# 2. Fill in the required API keys and database credentials.
# 3. Do not commit your `.env` file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Infrastructure & Core Settings
# ------------------------------------------------------------------------------
APP_ENV=dev                      # Options: dev, research, production
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_local_password_here
MYSQL_DB=protodb

# ------------------------------------------------------------------------------
# 2. Symbolic-Neural Engine (LLM Provider Selection)
# ------------------------------------------------------------------------------
# Choose the primary linguistic mediator: 'runpod', 'openai', 'anthropic', or 'ollama'
DEFAULT_LLM_PROVIDER=runpod
LLM_TIMEOUT_SECONDS=60
ENABLE_IMPLICIT=true             # Orchestrates the clausal routing engine
ENABLE_LLM_VERIFIER=true         # Enables Stage B Reasoned Recovery

# ------------------------------------------------------------------------------
# 3. Cloud Provider Configuration
# ------------------------------------------------------------------------------
# RunPod Serverless (Primary for Research Scaling)
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/your_endpoint_id/runsync

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------------------------
# 4. Local Inference (Fallbacks)
# ------------------------------------------------------------------------------
# Ollama (Local Serverless Fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# HuggingFace (For ProtoNet Encoder model downloads)
HF_TOKEN=your_huggingface_token_here

# ------------------------------------------------------------------------------
# 5. Model Hyperparameters & Research Gates
# ------------------------------------------------------------------------------
# Pre-extraction Sequence-to-Sequence (Local Fallback)
SEQ2SEQ_MODEL_NAME=google/flan-t5-small
SEQ2SEQ_MAX_NEW_TOKENS=192
SEQ2SEQ_TEMPERATURE=0.0

# Quality Thresholds
IMPLICIT_MIN_CONFIDENCE=0.08      # Heuristic Stage A gateway
LOW_CONFIDENCE_THRESHOLD=0.55    # Protonet uncertainty flag

# ------------------------------------------------------------------------------
# 6. Prototypical Network Integration
# ------------------------------------------------------------------------------
PROTONET_MODE=import             # Options: import, remote
PROTONET_URL=http://127.0.0.1:8011

# ------------------------------------------------------------------------------
# 7. Metadata (Optional)
# ------------------------------------------------------------------------------
USER_NAME=Your Name
USER_EMAIL=you@example.com
